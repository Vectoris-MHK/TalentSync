{
  "name": "talentsync",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=18.17.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm --filter client build",
    "lint": "pnpm --filter client lint && echo '[server] no lint configured'",
    "install:all": "pnpm install",
    "clean": "pnpm -r exec rm -rf node_modules && rm -rf node_modules"
  },
  "devDependencies": {
    "concurrently": "catalog:"
  }
}
