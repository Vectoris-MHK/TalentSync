# Force pnpm only — reject npm/yarn installs
engine-strict=true

# Hoist all to root node_modules (mặc định của pnpm workspace)
# Không cần shamefully-hoist vì pnpm đã xử lý workspace đúng cách

# Lưu lockfile đúng vị trí (root repo), không sinh trong sub-packages
lockfile=true
modules-cache-max-age=604800

# Public registry
registry=https://registry.npmjs.org/
